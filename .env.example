# FireSmart Environment Configuration
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Configuration
VITE_API_URL=http://localhost:3000/api

# Formspree Contact Form
# Create a form in Formspree, then paste the endpoint here.
# Example: https://formspree.io/f/abcxyz
VITE_FORMSPREE_ENDPOINT=your_formspree_endpoint_here

# WhatsApp Business API
VITE_WHATSAPP_API_KEY=your_whatsapp_api_key_here
VITE_WHATSAPP_PHONE_ID=your_whatsapp_phone_id_here

# SMS Service (e.g., Twilio)
VITE_SMS_API_KEY=your_sms_api_key_here

# Google Analytics
VITE_GA_ID=your_google_analytics_id_here

# App Configuration
VITE_APP_NAME=FireSmart
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://firesmart.io
VITE_NODE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_CONTACT_FORM=true
